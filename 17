using System;

namespace LeapYearCheck
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Работа 3. Проверка високосного года";
            
            Console.Write("Введите номер года: ");
            int year = int.Parse(Console.ReadLine());
            
            bool isLeap;
            
            if (year % 400 == 0)
            {
                isLeap = true; 
            }
            else if (year % 100 == 0)
            {
                isLeap = false; 
            }
            else if (year % 4 == 0)
            {
                isLeap = true; 
            }
            else
            {
                isLeap = false;
            }
            
            Console.WriteLine($"\nГод {year} {(isLeap ? "является" : "не является")} високосным");
            
            bool isLeapDotNet = DateTime.IsLeapYear(year);
            Console.WriteLine($"Проверка через DateTime.IsLeapYear: {isLeapDotNet}");
            
            if (isLeap)
            {
                Console.WriteLine($"\nВ этом году 366 дней");
                Console.WriteLine($"Дополнительный день - 29 февраля");
            }
            else
            {
                Console.WriteLine($"\nВ этом году 365 дней");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
