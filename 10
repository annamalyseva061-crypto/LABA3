using System;

namespace MinMaxOfThree
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = " Min/Max из трех чисел";
            
            Console.Write("Введите первое число: ");
            double a = double.Parse(Console.ReadLine());
            
            Console.Write("Введите второе число: ");
            double b = double.Parse(Console.ReadLine());
            
            Console.Write("Введите третье число: ");
            double c = double.Parse(Console.ReadLine());
            
            Console.WriteLine($"\nЧисла: {a}, {b}, {c}\n");
            
            double max = a;
            if (b > max) max = b;
            if (c > max) max = c;
            
            double min = a;
            if (b < min) min = b;
            if (c < min) min = c;
            
            Console.WriteLine($"Наибольшее число: {max}");
            Console.WriteLine($"Наименьшее число: {min}");
            
            double maxAlt = Math.Max(a, Math.Max(b, c));
            double minAlt = Math.Min(a, Math.Min(b, c));
            
            Console.WriteLine($"\nПроверка с Math.Max/Math.Min:");
            Console.WriteLine($"Наибольшее: {maxAlt}");
            Console.WriteLine($"Наименьшее: {minAlt}");
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
