using System;

namespace DayOfWeekWithStart
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Работа 3. День недели с заданным началом года";
            
            Console.Write("Введите номер дня в году k (1-365): ");
            int k = int.Parse(Console.ReadLine());
            
            if (k < 1 || k > 365)
            {
                Console.WriteLine("Ошибка: число должно быть от 1 до 365");
                Console.ReadKey();
                return;
            }
            
            int dayOfWeekNumA = (k - 1) % 7 + 1;
            string[] weekDays = { 
                "понедельник", "вторник", "среда", "четверг", 
                "пятница", "суббота", "воскресенье" 
            };
            
            Console.WriteLine($"\nа) Если 1 января - понедельник:");
            Console.WriteLine($"{k}-й день года - это {weekDays[dayOfWeekNumA - 1]}");
            
            Console.WriteLine("\nб) С заданным днем недели для 1 января:");
            Console.WriteLine("Введите номер дня недели для 1 января:");
            Console.WriteLine("1 - понедельник, 2 - вторник, ..., 7 - воскресенье");
            
            Console.Write("d = ");
            int d = int.Parse(Console.ReadLine());
            
            if (d < 1 || d > 7)
            {
                Console.WriteLine("Ошибка: номер дня недели должен быть от 1 до 7");
            }
            else
            {
                int dayOfWeekNumB = (d + (k - 1) - 1) % 7 + 1;
                Console.WriteLine($"{k}-й день года - это {weekDays[dayOfWeekNumB - 1]}");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
